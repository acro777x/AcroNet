<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- VanishMode Overlay -->
    <View
        android:id="@+id/viewVanishOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_vanish_overlay"
        android:visibility="gone"
        android:elevation="100dp" />

    <!-- Top App Bar -->
    <LinearLayout
        android:id="@+id/chatAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="#0D0D11"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/circle_btn_bg"
            android:tint="#00FFFF"
            tools:ignore="UseAppTint" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPeerId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AcroNet Identity"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quantum Secured"
                android:textColor="#00FFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btnSelfDestruct"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_vault_timer" />

        <ImageView
            android:id="@+id/btnVanishMode"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@drawable/ic_vault_self_destruct" />
    </LinearLayout>

    <!-- Message List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/chatAppBar"
        app:layout_constraintBottom_toTopOf="@id/inputContainer" />

    <!-- Frosted Input Field -->
    <LinearLayout
        android:id="@+id/inputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:gravity="bottom"
        android:background="#0A0A0C"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_glass_input"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/btnAttach"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:src="@drawable/ic_vault_attachment" />

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Encrypted Message"
                android:textColorHint="#66FFFFFF"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="8dp"
                android:paddingVertical="12dp"
                android:maxLines="6" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btnSend"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:padding="12dp"
            android:background="@drawable/circle_btn_bg"
            android:src="@drawable/ic_vault_mic" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
