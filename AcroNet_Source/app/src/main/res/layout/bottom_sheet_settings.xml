<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0A0A0F"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Settings"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <!-- Notifications -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="16dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Push Notifications"
            android:textColor="#CCCCDD"
            android:textSize="16sp" />
        <Switch
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:thumbTint="#00F0FF"
            android:trackTint="#333344" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A1A2E" />

    <!-- Two-Factor -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="16dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Two-Factor Authentication"
            android:textColor="#CCCCDD"
            android:textSize="16sp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enabled"
            android:textColor="#22C55E"
            android:textSize="14sp" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A1A2E" />

    <!-- Default Currency -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="16dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Default Currency"
            android:textColor="#CCCCDD"
            android:textSize="16sp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="USD"
            android:textColor="#888899"
            android:textSize="14sp" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A1A2E" />

    <!-- Price Alerts -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="16dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Price Alerts"
            android:textColor="#CCCCDD"
            android:textSize="16sp" />
        <Switch
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:thumbTint="#00F0FF"
            android:trackTint="#333344" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A1A2E" />

    <!-- Privacy Policy -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="16dp"
        android:text="Privacy Policy"
        android:textColor="#CCCCDD"
        android:textSize="16sp" />
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A1A2E" />

    <!-- Terms of Service -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="16dp"
        android:text="Terms of Service"
        android:textColor="#CCCCDD"
        android:textSize="16sp" />
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A1A2E" />

    <!-- Version -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="16dp"
        android:text="Version 2.4.1 (Build 847)"
        android:textColor="#555566"
        android:textSize="14sp"
        android:gravity="center" />
</LinearLayout>
